{
    "info": {
        "name": "Restful Booker — Full QA Test Suite",
        "description": "Complete API test collection for the Restful Booker API. Covers authentication, full CRUD operations for bookings, error handling, edge cases, and data validation. Built as a portfolio QA sample demonstrating structured API testing with Postman.\n\nBase URL: https://restful-booker.herokuapp.com\nAuthor: Tiraj Basnet | AI & SaaS QA Engineer\nVersion: 1.0.0",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "https://restful-booker.herokuapp.com",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        },
        {
            "key": "booking_id",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "description": "Authentication endpoints — generate and validate tokens.",
            "item": [
                {
                    "name": "Create Token — valid credentials",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// First things first, let's make sure the endpoint is actually responding with a 200 OK.",
                                    "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                                    "",
                                    "// Now we need to extract the token from the response so we can use it in later, authenticated requests.",
                                    "pm.test('Response has token', () => {",
                                    "  const json = pm.response.json();",
                                    "  pm.expect(json).to.have.property('token');",
                                    "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                                    "  // Storing the token at the collection level makes it super easy to reuse!",
                                    "  pm.collectionVariables.set('token', json.token);",
                                    "});",
                                    "",
                                    "// Just a quick sanity check to ensure the API didn't return an error string instead of a token.",
                                    "pm.test('Token is not null or undefined', () => {",
                                    "  pm.expect(pm.response.json().token).to.not.equal('Bad credentials');",
                                    "});",
                                    "",
                                    "// We also want to make sure the API is reasonably fast. Anything under 2 seconds is acceptable here.",
                                    "pm.test('Response time is under 2000ms', () => pm.expect(pm.response.responseTime).to.be.below(2000));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/auth",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
                        }
                    }
                },
                {
                    "name": "Create Token — invalid credentials",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Fun fact: This specific API has a quirk where it returns a 200 OK even when credentials fail.",
                                    "// We're testing for a 200 here just to match the API's actual (albeit weird) behavior.",
                                    "pm.test('Status is 200 (API quirk — returns 200 with error body)', () => pm.response.to.have.status(200));",
                                    "",
                                    "// Since we used bad credentials, we expect a very specific error message back.",
                                    "pm.test('Returns Bad credentials message', () => {",
                                    "  const json = pm.response.json();",
                                    "  pm.expect(json.reason).to.equal('Bad credentials');",
                                    "});",
                                    "",
                                    "// And of course, no token should be generated for an invalid login.",
                                    "pm.test('No token returned', () => {",
                                    "  pm.expect(pm.response.json()).to.not.have.property('token');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/auth",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"wronguser\",\n  \"password\": \"wrongpass\"\n}"
                        }
                    }
                },
                {
                    "name": "Create Token — missing password field",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// What happens if we just completely forget to send a password? Let's check.",
                                    "pm.test('Returns error for missing field', () => {",
                                    "  const json = pm.response.json();",
                                    "  // We should see some kind of error 'reason' in the response.",
                                    "  pm.expect(json).to.have.property('reason');",
                                    "});",
                                    "",
                                    "// Again, making absolutely sure no token is leaked when the request is malformed.",
                                    "pm.test('No token in response', () => {",
                                    "  pm.expect(pm.response.json()).to.not.have.property('token');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": "{{base_url}}/auth",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"username\": \"admin\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Bookings — Read",
            "description": "GET endpoints — retrieve all bookings and individual booking details.",
            "item": [
                {
                    "name": "Get All Bookings",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Basic check: is the API up and returning a 200 OK?",
                                    "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                                    "",
                                    "// The /booking endpoint should give us an array of booking IDs.",
                                    "pm.test('Response is an array', () => {",
                                    "  pm.expect(pm.response.json()).to.be.an('array');",
                                    "});",
                                    "",
                                    "// Since we're hitting a public test API, it's pretty safe to assume there's at least one booking in the system.",
                                    "pm.test('Array is not empty', () => {",
                                    "  pm.expect(pm.response.json().length).to.be.above(0);",
                                    "});",
                                    "",
                                    "// Let's loop through the results and make sure every single item has a valid 'bookingid'.",
                                    "pm.test('Each item has bookingid', () => {",
                                    "  pm.response.json().forEach(item => {",
                                    "    pm.expect(item).to.have.property('bookingid');",
                                    "    pm.expect(item.bookingid).to.be.a('number');",
                                    "  });",
                                    "});",
                                    "",
                                    "// Always good practice to verify we're actually getting JSON back.",
                                    "pm.test('Content-Type is application/json', () => {",
                                    "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                                    "});",
                                    "",
                                    "// Performance check! Let's make sure fetching all bookings doesn't take ages.",
                                    "pm.test('Response time is under 3000ms', () => pm.expect(pm.response.responseTime).to.be.below(3000));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/booking"
                    }
                },
                {
                    "name": "Get All Bookings — filter by firstname",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Testing our query parameters. We should still get a 200 OK here.",
                                    "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                                    "",
                                    "// Even if the filter finds nothing, it should return an empty array, not an error or a different data structure.",
                                    "pm.test('Response is an array', () => {",
                                    "  pm.expect(pm.response.json()).to.be.an('array');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/booking?firstname=Jim",
                            "query": [
                                {
                                    "key": "firstname",
                                    "value": "Jim"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get All Bookings — filter by checkin date",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Checking if the date filtering works correctly.",
                                    "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                                    "",
                                    "// Same as the firstname filter, we always expect an array back.",
                                    "pm.test('Response is an array', () => {",
                                    "  pm.expect(pm.response.json()).to.be.an('array');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{base_url}}/booking?checkin=2024-01-01",
                            "query": [
                                {
                                    "key": "checkin",
                                    "value": "2024-01-01"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Single Booking — valid ID",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "// If we're running this request in isolation and don't have a booking_id saved yet, ",
                                    "// let's just fall back to ID '1' so the request doesn't fail out of the gate.",
                                    "if (!pm.collectionVariables.get('booking_id')) {",
                                    "  pm.collectionVariables.set('booking_id', '1');",
                                    "}"
                                ]
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Checking that the specific booking was retrieved successfully.",
                                    "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                                    "",
                                    "// This is a strict schema check. We want to ensure all these exact keys exist in the response.",
                                    "pm.test('Response has required fields', () => {",
                                    "  const json = pm.response.json();",
                                    "  pm.expect(json).to.have.all.keys('firstname', 'lastname', 'totalprice', 'depositpaid', 'bookingdates', 'additionalneeds');",
                                    "});",
                                    "",
                                    "// Let's do some data type validations. Price should definitely be a positive number.",
                                    "pm.test('totalprice is a positive number', () => {",
                                    "  pm.expect(pm.response.json().totalprice).to.be.a('number').and.above(0);",
                                    "});",
                                    "",
                                    "// Deposit paid should be a simple true/false boolean.",
                                    "pm.test('depositpaid is boolean', () => {",
                                    "  pm.expect(pm.response.json().depositpaid).to.be.a('boolean');",
                                    "});",
                                    "",
                                    "// The booking dates object should contain both a check-in and check-out date.",
                                    "pm.test('bookingdates has checkin and checkout', () => {",
                                    "  const dates = pm.response.json().bookingdates;",
                                    "  pm.expect(dates).to.have.property('checkin');",
                                    "  pm.expect(dates).to.have.property('checkout');",
                                    "});",
                                    "",
                                    "// Making sure names are coming back as strings.",
                                    "pm.test('firstname and lastname are strings', () => {",
                                    "  const json = pm.response.json();",
                                    "  pm.expect(json.firstname).to.be.a('string');",
                                    "  pm.expect(json.lastname).to.be.a('string');",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/booking/{{booking_id}}"
                    }
                },
