                    "name": "Get Single Booking — non-existent ID",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Let's try to fetch a booking that definitely doesn't exist.",
                                    "// We expect a standard 404 Not Found status here.",
                                    "pm.test('Status is 404 for non-existent booking', () => pm.response.to.have.status(404));"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/booking/999999"
                    }
                },
                {
                    "name": "Get Single Booking — invalid ID format",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// Sending letters instead of numbers for an ID.",
                                    "// Depending on how the backend routes are set up, this might be a 400 Bad Request or a 404 Not Found.",
                                    "// We'll accept either as valid error handling.",
                                    "pm.test('Returns error for invalid ID format', () => {",
                                    "  pm.expect(pm.response.code).to.be.oneOf([400, 404]);",
                                    "});"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "method": "GET",
                        "url": "{{base_url}}/booking/abc"
                    }
                }
            ]
        },
        {
            "name": "Bookings — Create",
            "description": "POST endpoint — create new bookings with various data scenarios.",
            "item": [
                {
                    "name": "Create Booking — valid full payload",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "// A successful creation should return a 200 OK.",
                                    "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                                    "",
                                    "// We need the new booking ID for our future tests (like update and delete), so let's save it!",
                                    "pm.test('Response has bookingid', () => {",
                                    "  const json = pm.response.json();",
                                    "  pm.expect(json).to.have.property('bookingid');",
                                    "  pm.expect(json.bookingid).to.be.a('number');",
                                    "  // Save it to collection variables",
                                    "  pm.collectionVariables.set('booking_id', json.bookingid);",
                                    "});",
                                    "",
                                    "// The API wraps the returned data in a 'booking' object, let's make sure it's there.",
                                    "pm.test('Response contains booking object', () => {",
                                    "  pm.expect(pm.response.json()).to.have.property('booking');",
                                    "});",
                                    "",
                                    "// Now let's verify the data we sent is exactly what got saved.",
                                    "pm.test('Booking data matches request payload', () => {",
                                    "  const booking = pm.response.json().booking;",
                                    "  pm.expect(booking.firstname).to.equal('James');",
                                    "  pm.expect(booking.lastname).to.equal('Brown');",
                                    "  pm.expect(booking.totalprice).to.equal(150);",
                                    "  pm.expect(booking.depositpaid).to.equal(true);",
                                    "});",
                                    "",
                                    "// Double-checking the dates made it through correctly too.",
                                    "pm.test('Booking dates are saved correctly', () => {",
                                    "  const dates = pm.response.json().booking.bookingdates;",
                                    "  pm.expect(dates.checkin).to.equal('2025-06-01');",
                                    "  pm.expect(dates.checkout).to.equal('2025-06-07');",
                                    "});"
                                ]
                            }
                        }
                    ],
